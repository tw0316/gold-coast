  "dependencies": {
    "@aws-sdk/client-s3": "3.1063.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "next": "16.2.7",
    "payload": "3.85.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
