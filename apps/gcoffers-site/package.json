  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run payload:importmap",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
