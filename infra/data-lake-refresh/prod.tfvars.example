environment      = "prod"
region           = "us-east-1"
data_lake_bucket = "gcoffers-data-lake"
data_lake_s3_prefix = ""
glue_database    = "gold_coast"
reporting_glue_database = "gold_coast_reporting"
athena_workgroup = "gold_coast_data_lake"
image_tag        = "REPLACE_WITH_SHARED_FALLBACK_GIT_SHA"
refresh_image_tag = "REPLACE_WITH_REFRESH_GIT_SHA"
transcription_image_tag = "REPLACE_WITH_TRANSCRIPTION_GIT_SHA"
task_cpu_architecture = "ARM64"
schedule_enabled = false
schedule_expression = "rate(1 hour)"
transcription_schedule_enabled = false
transcription_schedule_expression = "rate(1 hour)"
transcription_max_transcriptions_per_run = 10
transcription_artifact_schema_version = "v1"
transcription_provider = "openai"
transcription_model = "gpt-4o-transcribe"
transcription_fallback_model = "whisper-1"

# Core GHL refresh alert settings.
alert_mode = "failure-only"

# For the first 1-2 core refresh launch days, set alert_mode = "launch-window" and fill this.
success_alert_until = null

# Call transcription alert settings.
transcription_alert_mode = "failure-only"

# For the first 1-2 transcription launch days, set transcription_alert_mode = "launch-window" and fill this.
transcription_success_alert_until = null

# Fill these from the approved VPC before planning.
vpc_id            = "vpc-REPLACE"
public_subnet_ids = ["subnet-REPLACE-A", "subnet-REPLACE-B"]

# Store secret values in AWS Secrets Manager. Do not put secret values here.
# The Slack webhook secret must target the reusable Gold Coast tech-alerts channel C0B4JTC5VPF.
ghl_api_key_secret_arn     = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:gold-coast/ghl/api-key-REPLACE"
ghl_location_id_secret_arn = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:gold-coast/ghl/location-id-REPLACE"
slack_webhook_secret_arn   = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:gold-coast/slack/tech-alerts-webhook-REPLACE"
openai_transcription_secret_arn = "arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:goldcoast/openai-api-key-REPLACE"
